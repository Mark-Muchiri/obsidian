# Setup state — gitignored so progress is machine-local
state/

# Editor swap files
*.swp
*.swo

# macOS metadata (in case the repo is ever touched on a Mac)
.DS_Store

# Timestamped backups created by safe_symlink and restore.sh --unlink
*.bak.*

# Secrets — never commit these
*.pem
*.key
id_ed25519
id_rsa
configs/micro/micro/backups/
configs/micro/micro/buffers/
configs/micro/micro/settings.json
configs/google-chrome-stable-flags.conf/
