{
  // ╔══════════════════════════════════════════════════════════╗
  // ║                   WINDOW & WORKBENCH                    ║
  // ╚══════════════════════════════════════════════════════════╝

  // -- Menu & Title Bar --
  "window.menuBarVisibility": "toggle",
  "window.customTitleBarVisibility": "never",
  "window.menuStyle": "custom",
  "window.commandCenter": false,

  // -- Startup & Restore --
  "window.restoreWindows": "none",
  "workbench.startupEditor": "none",

  // -- Theme & Icons --
  "window.autoDetectColorScheme": true,
  "workbench.preferredDarkColorTheme": "Aura Dark (Soft Text)",
  "workbench.preferredHighContrastColorTheme": "Aura Dark (Soft Text)",
  "workbench.iconTheme": "a-file-icon-vscode",

  // -- Layout & UI Chrome --
  "workbench.layoutControl.enabled": false,
  "workbench.sideBar.location": "right",
  "workbench.browser.showInTitleBar": false,
  "workbench.tips.enabled": false,
  "chat.commandCenter.enabled": false,

  // -- Tabs --
  "workbench.editor.showTabs": "single",
  "workbench.editor.tabSizing": "fixed",
  "workbench.editor.tabSizingFixedMaxWidth": 110,
  "workbench.editor.pinnedTabSizing": "compact",
  "workbench.editor.tabActionLocation": "left",
  "workbench.editor.enablePreviewFromQuickOpen": true,
  "workbench.editor.enablePreviewFromCodeNavigation": true,

  // -- Scrolling & Lists --
  "workbench.list.smoothScrolling": true,
  "workbench.list.mouseWheelScrollSensitivity": 0.5,
  "workbench.tree.enableStickyScroll": false,

  // ╔══════════════════════════════════════════════════════════╗
  // ║                  COLOR CUSTOMIZATIONS                   ║
  // ╚══════════════════════════════════════════════════════════╝

  "workbench.colorCustomizations": {
    // -- Dark Blue Base --
    "statusBar.background": "#01050a",
    "sideBar.background": "#01050a",
    "activityBar.background": "#01050a",
    "terminal.background": "#01050a",
    "editor.background": "#01050a",

    // -- Editor Line Highlight (transparent) --
    "editor.lineHighlightBackground": "#01192c00",
    "editor.lineHighlightBorder": "#1e1e1e00",

    // -- Cursor --
    "editorCursor.foreground": "#585858",

    // -- Scrollbar --
    "scrollbarSlider.activeBackground": "#1316289d",
    "scrollbarSlider.background": "#1a1c3496",
    "scrollbarSlider.hoverBackground": "#1a1c3496",

    // -- Minimap Scrollbar --
    "minimapSlider.activeBackground": "#0d0f1a96",
    "minimapSlider.background": "#11132196",
    "minimapSlider.hoverBackground": "#11132196"
  },

  // ╔══════════════════════════════════════════════════════════╗
  // ║                   EDITOR: TYPOGRAPHY                    ║
  // ╚══════════════════════════════════════════════════════════╝

  "editor.fontFamily": "JetBrainsMono Nerd Font Mono",
  "editor.fontSize": 18,
  "editor.fontWeight": "200",
  "editor.fontLigatures": true,

  // ╔══════════════════════════════════════════════════════════╗
  // ║                  EDITOR: TEXT & WRAPPING                ║
  // ╚══════════════════════════════════════════════════════════╝

  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 70,
  "editor.wrappingIndent": "none",
  "editor.wrappingStrategy": "advanced",
  "editor.tabSize": 2,
  "editor.tabCompletion": "on",
  "editor.renderWhitespace": "none",

  // ╔══════════════════════════════════════════════════════════╗
  // ║                 EDITOR: CURSOR & SCROLL                 ║
  // ╚══════════════════════════════════════════════════════════╝

  "editor.cursorWidth": 4,
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.overtypeCursorStyle": "line",
  "editor.smoothScrolling": true,
  "editor.inertialScroll": true,
  "editor.mouseWheelScrollSensitivity": 0.5,

  // ╔══════════════════════════════════════════════════════════╗
  // ║                EDITOR: SCROLLBAR & MINIMAP              ║
  // ╚══════════════════════════════════════════════════════════╝

  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "visible",
  "editor.scrollbar.horizontalScrollbarSize": 15,
  "editor.scrollbar.verticalScrollbarSize": 12,
  "editor.minimap.enabled": false,
  "editor.minimap.maxColumn": 40,
  "editor.minimap.scale": 2,
  "editor.minimap.showSlider": "always",
  "editor.minimap.renderCharacters": false,

  // ╔══════════════════════════════════════════════════════════╗
  // ║              EDITOR: FORMATTING & COMPLETION            ║
  // ╚══════════════════════════════════════════════════════════╝

  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.autoClosingBrackets": "always",
  "editor.autoClosingDelete": "always",
  "editor.linkedEditing": true,
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.inlineSuggest.fontFamily": "'JetBrainsMono Nerd Font Propo'",
  "editor.quickSuggestions": {
    "strings": true
  },

  // ╔══════════════════════════════════════════════════════════╗
  // ║               EDITOR: VISUAL GUIDES & HINTS             ║
  // ╚══════════════════════════════════════════════════════════╝

  // -- Bracket Pairs --
  "editor.guides.bracketPairs": true,
  "editor.guides.bracketPairsHorizontal": false,
  "editor.matchBrackets": "never",
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,

  // -- Indentation Guides --
  "editor.guides.highlightActiveIndentation": "always",
  "editor.guides.indentation": false,

  // -- Highlights (disabled for clean look) --
  "editor.selectionHighlight": false,
  "editor.occurrencesHighlight": "off",
  "editor.unicodeHighlight.invisibleCharacters": false,

  // -- Other Visual Features --
  "editor.folding": false,
  "editor.glyphMargin": false,
  "editor.codeLens": false,
  "editor.stickyScroll.enabled": false,
  "editor.stickyScroll.scrollWithEditor": false,

  // -- Supplementary Font Families --
  "editor.codeLensFontFamily": "'VictorMono Nerd Font Propo'",
  "editor.inlayHints.fontFamily": "'JetBrainsMono Nerd Font Propo'",

  // -- Performance --
  "editor.accessibilitySupport": "off",
  "editor.largeFileOptimizations": true,

  // ╔══════════════════════════════════════════════════════════╗
  // ║                      TERMINAL                           ║
  // ╚══════════════════════════════════════════════════════════╝

  // -- Default Shell --
  "terminal.integrated.defaultProfile.linux": "zsh (2)",

  // -- Typography --
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.fontWeight": "200",

  // -- Cursor --
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorWidth": 4,

  // -- Ligatures --
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.fontLigatures.featureSettings": "\"liga\" on",
  "terminal.integrated.fontLigatures.fallbackLigatures": [
    "<--", "<---", "<<-", "<-", "->", "->>", "-->", "--->",
    "<==", "<===", "<<=", "<=", "=>", "=>>", "==>", "===>",
    ">=", ">>=", "<->", "<-->", "<--->", "<---->",
    "<=>", "<==>", "<===>", "<====>",
    "::", ":::", "<~~", "</", "</>", "/>", "~~>",
    "==", "!=", "/=", "~=", "<>", "===", "!==", "!===",
    "<:", ":=", "*=", "*+", "<*", "<*>", "*>",
    "<|", "<|>", "|>", "+*", "=*", "=:", ":>",
    "/*", "*/", "+++", "<!--", "<!---"
  ],

  // -- Behaviour --
  "terminal.integrated.enableImages": true,
  "terminal.integrated.enableMultiLinePasteWarning": "auto",
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.customGlyphs": false,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.mouseWheelScrollSensitivity": 0.5,
  "terminal.integrated.env.linux": {},

  // -- Shell Profiles --
  "terminal.integrated.profiles.linux": {
    "bash": {
      "path": "bash",
      "icon": "terminal-bash"
    },
    "zsh": {
      "path": "zsh"
    },
    "zsh (2)": {
      "path": "/bin/zsh"
    },
    "fish": {
      "path": "fish"
    },
    "tmux": {
      "path": "tmux",
      "icon": "terminal-tmux"
    },
    "tmux (2)": {
      "path": "/bin/tmux"
    },
    "pwsh": {
      "path": "pwsh",
      "icon": "terminal-powershell"
    }
  },

  // ╔══════════════════════════════════════════════════════════╗
  // ║                  GIT & SOURCE CONTROL                   ║
  // ╚══════════════════════════════════════════════════════════╝

  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.postCommitCommand": "sync",
  "git.allowForcePush": true,
  "git.alwaysShowStagedChangesResourceGroup": true,
  "git.openRepositoryInParentFolders": "never",
  "git.ignoredRepositories": [
    "/home/mac/.vscode/extensions/stepsize.stepsize-1.0.15/resources/demo-repository"
  ],
  "githubPullRequests.createOnPublishBranch": "never",
  "scm.compactFolders": false,
  "scm.inputFontFamily": "'JetBrainsMono Nerd Font Propo'",

  // ╔══════════════════════════════════════════════════════════╗
  // ║               LANGUAGE & FILE ASSOCIATIONS              ║
  // ╚══════════════════════════════════════════════════════════╝

  // -- Emmet --
  "emmet.includeLanguages": {
    "rust": "html",
    "javascript": "javascriptreact"
  },

  // -- File Type Associations --
  "files.associations": {
    "css": "css",
    "html": "html",
    "*.js": "javascript",
    "*.css": "css",
    "*.html": "html",
    "*.tsx": "typescriptreact"
  },

  // -- JavaScript / TypeScript --
  "javascript.format.semicolons": "insert",
  "typescript.format.semicolons": "insert",
  "javascript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBrackets": true,
  "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBrackets": true,
  "js/ts.implicitProjectConfig.experimentalDecorators": true,

  // -- HTML & CSS --
  "html.format.wrapLineLength": 70,
  "css.validate": false,
  "tailwindCSS.emmetCompletions": true,

  // -- Per-Language Formatter Overrides --
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features",
    "editor.language.colorizedBracketPairs": [
      ["<", ">"],
      ["{", "}"],
      ["(", ")"],
      ["[", "]"]
    ]
  },
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[toml]": {
    // "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "[git-commit]": {
    // "editor.defaultFormatter": "adam-bender.commit-message-formatter"
  },

  // ╔══════════════════════════════════════════════════════════╗
  // ║                    FILE MANAGEMENT                      ║
  // ╚══════════════════════════════════════════════════════════╝

  // -- Auto Save --
  "files.autoSave": "afterDelay",

  // -- Dialog Preferences --
  "files.simpleDialog.enable": true,

  // -- Read-only Rules --
  "files.readonlyFromPermissions": true,
  "files.readonlyInclude": {
    "**/.cargo/registry/src/**/*.rs": true,
    "**/.cargo/git/checkouts/**/*.rs": true,
    "**/lib/rustlib/src/rust/library/**/*.rs": true
  },

  // -- Watcher Exclusions (reduces CPU usage) --
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/env/**": true,
    "**/venv/**": true,
    "env-*": true
  },

  // -- Explorer Exclusions (hides noisy directories) --
  "files.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "node_modules": true,
    "venv": true,
    "*.sublime-*": true
  },

  // -- Search Exclusions --
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/env": true,
    "**/venv": true
  },

  // ╔══════════════════════════════════════════════════════════╗
  // ║                FILE EXPLORER BEHAVIOUR                  ║
  // ╚══════════════════════════════════════════════════════════╝

  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.incrementalNaming": "smart",
  "explorer.compactFolders": false,

  // ╔══════════════════════════════════════════════════════════╗
  // ║                  EXTENSIONS & PLUGINS                   ║
  // ╚══════════════════════════════════════════════════════════╝

  // -- Icons --
  "material-icon-theme.hidesExplorerArrows": true,

  // -- Live Server --
  "liveServer.settings.donotShowInfoMsg": true,

  // -- TODO Highlight: Keyword Definitions --
  "todohighlight.keywords": [
    {
      "text": "TODO:",
      "regex": { "pattern": "(?<=^|\"|\\s)TODO(\\(\\w+\\))?:" },
      "color": "red",
      "border": "1px solid red",
      "borderRadius": "2px",
      "backgroundColor": "rgba(0,0,0,.2)"
    },
    {
      "text": "FIXME",
      "regex": { "pattern": "(?<=^|\"|\\s)FIXME(\\(\\w+\\))?:" },
      "color": "pink",
      "border": "1px solid pink",
      "borderRadius": "2px",
      "backgroundColor": "rgba(0,0,0,.2)"
    },
    {
      "text": "NOTE:",
      "regex": { "pattern": "(?<=^|\"|\\s)NOTE[:]?(?!\\w)" },
      "color": "purple",
      "border": "1px solid purple",
      "borderRadius": "2px",
      "backgroundColor": "rgba(0,0,0,.2)",
      "isWholeLine": false
    },
    {
      "text": "INFO:",
      "color": "green",
      "border": "1px solid green",
      "borderRadius": "2px",
      "backgroundColor": "rgba(0,0,0,0)",
      "isWholeLine": false
    },
    {
      "text": "REVIEW",
      "regex": { "pattern": "(?<=^|\"|\\s)REVIEW(\\(\\w+\\))?:" },
      "color": "blue",
      "border": "1px solid blue",
      "borderRadius": "2px",
      "backgroundColor": "rgba(0,0,0,.2)"
    },
    {
      "text": "WARNING:",
      "before": { "contentText": "⚠️" },
      "after": { "contentText": "⚠️" },
      "color": "red",
      "border": "1px solid #E65C00",
      "borderRadius": "2px",
      "backgroundColor": "rgba(0,0,0,.2)",
      "diagnosticSeverity": "warning"
    }
  ],

  // -- TODO Highlight: File Inclusion / Exclusion --
  "todohighlight.include": [
    "**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx",
    "**/*.html", "**/*.php", "**/*.css", "**/*.scss"
  ],
  "todohighlight.exclude": [
    "**/node_modules/**", "**/bower_components/**",
    "**/dist/**", "**/build/**",
    "**/.vscode/**", "**/.github/**", "**/_output/**",
    "**/*.min.*", "**/*.map", "**/.next/**"
  ],
  "todohighlight.maxFilesForSearch": 5120,
  "todohighlight.toggleURI": false,

  // ╔══════════════════════════════════════════════════════════╗
  // ║               DEBUG, DIAGNOSTICS & MISC                 ║
  // ╚══════════════════════════════════════════════════════════╝

  "debug.console.fontFamily": "'JetBrainsMono Nerd Font Propo'",
  "diffEditor.experimental.showEmptyDecorations": false,

  // -- Accessibility --
  "accessibility.signals.chatRequestSent": {
    "sound": "on"
  },

  // -- Shell Resolution --
  "application.shellEnvironmentResolutionTimeout": 50,
  "application.experimental.rendererProfiling": true,

  // -- Telemetry & Updates --
  "telemetry.telemetryLevel": "off",
  "update.showReleaseNotes": false
}